    <script>
      const hdr = document.getElementById("hdr");
      const line = document.getElementById("hdr-line");
      const onScroll = () => { const s = window.scrollY > 20; hdr?.classList.toggle("scrolled", s); line?.classList.toggle("opacity-100", s); };
      window.addEventListener("scroll", onScroll, { passive: true }); onScroll();

      const mt = document.getElementById("mtoggle"); const mm = document.getElementById("mmenu");
      mt?.addEventListener("click", () => { const open = mm?.classList.toggle("hidden") === false; mm?.classList.toggle("flex", open); mt.setAttribute("aria-expanded", String(open)); });
      mm?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => { mm.classList.add("hidden"); mm.classList.remove("flex"); mt?.setAttribute("aria-expanded", "false"); }));

      const io = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } }); }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
      document.querySelectorAll(".reveal:not(.in)").forEach((el) => io.observe(el));
      setTimeout(() => document.querySelectorAll(".reveal:not(.in)").forEach((el) => el.classList.add("in")), 2500);

      // Quote form: validation + simulated submit (no backend in this draft)
      const form = document.getElementById("quoteForm");
      if (form) {
        const setErr = (input, msg) => { const e = input.parentElement.querySelector("[data-err]"); input.setAttribute("aria-invalid", "true"); if (e) e.textContent = msg; };
        const clrErr = (input) => { const e = input.parentElement.querySelector("[data-err]"); input.removeAttribute("aria-invalid"); if (e) e.textContent = ""; };
        const valid = (input) => {
          if (!input.hasAttribute("required")) return true;
          const v = (input.value || "").trim();
          if (!v) { setErr(input, "Dit veld is verplicht."); return false; }
          if (input.type === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) { setErr(input, "Vul een geldig e-mailadres in."); return false; }
          clrErr(input); return true;
        };
        form.querySelectorAll("input,select,textarea").forEach((i) => {
          i.addEventListener("blur", () => i.hasAttribute("required") && valid(i));
          i.addEventListener("input", () => i.getAttribute("aria-invalid") === "true" && valid(i));
        });
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          const intent = e.submitter && e.submitter.dataset.intent === "book" ? "book" : "info";
          let ok = true, first = null;
          form.querySelectorAll("[required]").forEach((i) => { if (!valid(i)) { ok = false; first = first || i; } });
          if (!ok) { first?.focus(); return; }
          form.querySelectorAll(".submitbtn").forEach((b) => b.setAttribute("disabled", ""));
          if (e.submitter) e.submitter.querySelector(".btn-label").textContent = "Versturen…";
          setTimeout(() => {
            const title = document.getElementById("successTitle");
            const msg = document.getElementById("successMsg");
            if (intent === "book") {
              title.textContent = "Bedankt voor uw boekingsaanvraag!";
              msg.textContent = "We bevestigen uw afspraak in de agenda en bezorgen u een veilige betaallink via Mollie.";
            } else {
              title.textContent = "Bedankt, uw vraag is verstuurd.";
              msg.textContent = "We nemen binnen enkele uren contact met u op.";
            }
            form.querySelectorAll(":scope > *:not(#formSuccess)").forEach((el) => (el.style.display = "none"));
            const s = document.getElementById("formSuccess"); s.classList.remove("hidden"); s.classList.add("flex");
          }, 1000);
        });
      }
    </script>
